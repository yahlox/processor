{
  "name": "yahlox/processor",
  "description": "A PHP workflow engine that parses ReactFlow JSON and supports Laravel package integration.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Yahlox Team",
      "role": "Developer"
    }
  ],
  "autoload": {
    "psr-4": {
      "Yahlox\\": "src/"
    }
  },
  "require": {
    "php": "^8.0",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/container": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0|^11.0",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.0",
    "rector/rector": "^0.18",
    "mockery/mockery": "^1.5"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html coverage",
    "analyze": "phpstan analyse src",
    "fix": "php-cs-fixer fix src",
    "rector": "rector process src --dry-run",
    "rector:apply": "rector process src",
    "benchmark": "php scripts/benchmark.php"
  }
}

