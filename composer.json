{
  "name": "yahlox/processor",
  "description": "A PHP workflow engine that parses ReactFlow JSON and supports Laravel package integration.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Yahlox\\": "src/"
    }
  },
  "require": {
    "php": "^8.4",
    "illuminate/support": "^13.0",
    "illuminate/container": "^13.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  }
  ,
  "scripts": {
    "benchmark": "php scripts/benchmark.php"
  }
}
